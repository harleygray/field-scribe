# Copy this file to .env and fill in values for local development.
# Never commit .env — it is in .gitignore.
# This file is loaded automatically via config/runtime.exs (dotenvy).

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Dev uses your local Postgres on localhost:5432.
# Prod uses the shared Fly cluster (civic-forum-db) — DATABASE_URL is set
# automatically as a Fly secret by `fly postgres attach`, so you don't
# write it here for prod.
DATABASE_URL=ecto://YOUR_PG_USER:YOUR_PG_PASSWORD@localhost/fieldscribe_dev

# ---------------------------------------------------------------------------
# OpenAI
# ---------------------------------------------------------------------------
# Used for both Whisper transcription and structured-output extraction.
OPENAI_API_KEY=sk-...

# ---------------------------------------------------------------------------
# Apps Script
# ---------------------------------------------------------------------------
# Web App URL of the deployed Apps Script project (priv/apps_script/Code.gs).
# Until set, the pipeline reaches :writing and surfaces an "Apps Script
# unreachable" error in the report's error_log.
APPS_SCRIPT_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------
# Days to keep priv/uploads/<id>.webm before the daily Oban Cron sweep
# deletes the file (the report row stays). Default 14.
# AUDIO_RETENTION_DAYS=14

# Phoenix secret key base. A safe development default lives in config/dev.exs.
# Override here only if you need to.
# SECRET_KEY_BASE=
